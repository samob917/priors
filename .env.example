# Database — Neon PostgreSQL
# Get these from https://console.neon.tech after creating a project
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/priors?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/priors?sslmode=require"

# NextAuth — generate a secret with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="https://your-app.vercel.app"

# Cron secret — protects cron endpoints in production
CRON_SECRET="your-cron-secret-here"
